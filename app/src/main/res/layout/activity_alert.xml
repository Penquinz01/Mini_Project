<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/alertRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#CC0000">

    <!-- Animated pulsing ring wrapper -->
    <FrameLayout
        android:id="@+id/iconFrame"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="28dp"
        android:background="@drawable/alert_icon_bg">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_dialog_alert"
            app:tint="#FFFFFF" />
    </FrameLayout>

    <!-- EMERGENCY header -->
    <TextView
        android:id="@+id/textAlertHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🚨 EMERGENCY ALERT"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:gravity="center"
        android:letterSpacing="0.08"
        android:layout_marginBottom="16dp" />

    <!-- Sound type label -->
    <TextView
        android:id="@+id/textAlertSoundType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Siren Detected"
        android:textColor="#FFE0E0"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- dB level + confidence -->
    <TextView
        android:id="@+id/textAlertDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="95 dB — Confidence: 87%"
        android:textColor="#FFCCCC"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginBottom="40dp" />

    <!-- Dismiss button -->
    <Button
        android:id="@+id/btnDismissAlert"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:text="✓  DISMISS"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#CC0000"
        android:backgroundTint="#FFFFFF"
        android:layout_marginTop="8dp" />

</LinearLayout>
