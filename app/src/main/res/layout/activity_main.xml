<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8F5E9"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal"
        android:background="#E8F5E9">

        <!-- Title -->
        <TextView
            android:id="@+id/textViewWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sound Level Monitor"
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewLogs"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📜 View Sound Logs"
            android:textSize="16sp"
            android:layout_marginBottom="20dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="12dp" />

        <!-- Request Permissions — hidden in code if already granted -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRequestPermissions"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🔐 Grant All Permissions"
            android:textSize="16sp"
            android:layout_marginBottom="20dp"
            app:cornerRadius="12dp" />

        <!-- Now Detecting Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardNowDetecting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:contentPadding="28dp"
            app:cardBackgroundColor="#C8E6C9">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOW DETECTING"
                    android:textSize="11sp"
                    android:textColor="#777777"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/textDetectedSound"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤫 Ambient"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/textDbLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- dB"
                    android:textSize="18sp"
                    android:textColor="#555555"
                    android:layout_marginBottom="20dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToggleMic"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🎙️ Start Monitoring"
                    android:textSize="14sp"
                    android:enabled="false"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Calibration / Threshold Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:contentPadding="20dp"
            app:cardBackgroundColor="#B2E0F7FA">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔔 Alert Threshold"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto-calibrated · recalibrates every 30s"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/textCurrentThreshold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current threshold: -- dB"
                    android:textSize="13sp"
                    android:textColor="@color/primary"
                    android:textStyle="italic" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCalibrate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🎯 Recalibrate Now"
                    android:textSize="14sp"
                    android:layout_marginTop="12dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:cornerRadius="12dp" />

                <TextView
                    android:id="@+id/textCalibrationStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginTop="6dp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Notification Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:contentPadding="20dp"
            app:cardBackgroundColor="#B2E0F7FA">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚨 Emergency Alerts"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Only urgent sounds trigger notifications"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Permission:"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/textStatusNotification"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Checking..."
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Full-screen alert status (Android 14+) -->
                <TextView
                    android:id="@+id/textStatusFullScreen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🚨 Full-Screen Alerts: Checking..."
                    android:textSize="13sp"
                    android:textColor="#CC0000"
                    android:textStyle="bold"
                    android:paddingTop="4dp"
                    android:paddingBottom="12dp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTestNotification"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🔔 Test Normal Notification"
                    android:textSize="14sp"
                    android:enabled="false"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:cornerRadius="12dp"
                    android:visibility="gone"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTestEmergency"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🚨 Test Emergency Alert"
                    android:textSize="14sp"
                    android:enabled="false"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="#F44336"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Microphone Permission Status -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:contentPadding="20dp"
            app:cardBackgroundColor="#B2E0F7FA">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Microphone Permission:"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/textStatusMic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Checking..."
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
