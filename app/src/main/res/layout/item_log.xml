<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardLogRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Icon / Type -->
        <TextView
            android:id="@+id/textLogIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="🔊"
            android:textSize="24sp"
            android:gravity="center"
            android:background="@drawable/rounded_bg"
            android:backgroundTint="#EEEEEE" />

        <!-- Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/textLogClass"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dog Bark"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/textLogTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:45 AM - Oct 12"
                android:textSize="12sp"
                android:textColor="#777777"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Stats -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/textLogDb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="85 dB"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#E65100" />

            <TextView
                android:id="@+id/textLogConfidence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="92% match"
                android:textSize="12sp"
                android:textColor="#388E3C" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
