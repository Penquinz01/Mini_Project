<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Theme.MiniProject" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">#FF00838F</item>
    </style>

    <!-- Full-screen emergency alert theme: no action bar, over lock screen -->
    <style name="Theme.MiniProject.Alert" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#CC0000</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">#AA0000</item>
    </style>
</resources>
